{
  "info": {
    "_postman_id": "b1a7f0c2-0001-4a10-9e00-ragsystemcol01",
    "name": "RAG System API",
    "description": "Koleksi endpoint RAG System backend (Gin + GORM, JWT). Import bersama environment `ragsystem.local.postman_environment.json`. Login menyimpan access_token & refresh_token ke environment; endpoint /users memakai Bearer {{access_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "health",
      "item": [
        {
          "name": "Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 503', function () { pm.expect([200,503]).to.include(pm.response.code); });",
                  "pm.test('no 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/healthz", "host": ["{{base_url}}"], "path": ["healthz"] }
          }
        }
      ]
    },
    {
      "name": "auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });",
                  "pm.test('password not returned', function () { pm.expect(pm.response.text()).to.not.include('\"password\"'); });",
                  "var j={}; try{ j=pm.response.json(); }catch(e){}",
                  "if (j.data && j.data.id) { pm.environment.set('user_id', j.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{new_user_name}}\",\n  \"email\": \"{{new_user_email}}\",\n  \"password\": \"{{new_user_password}}\",\n  \"organization_code\": \"{{organization_code}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "description": "ADMIN ONLY (role selalu jadi 'user'). Login sebagai admin dulu (lihat env: email/password = admin yang di-promote via SQL). 201 sukses · 401 tanpa token · 403 kalau bukan admin · 409 email sudah ada."
          }
        },
        {
          "name": "Register (bulk, admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"name\": \"User A\", \"email\": \"usera@pln.co.id\", \"organization_code\": \"pln\" },\n  { \"name\": \"User B\", \"email\": \"userb@icon.id\", \"organization_code\": \"icon\" }\n]",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/register/bulk", "host": ["{{base_url}}"], "path": ["auth", "register", "bulk"] },
            "description": "ADMIN ONLY. Body = array of user (tanpa password; di-generate server). Partial success: response berisi results[] per-item dengan temp_password pada yang sukses. Maks 100 item. 401 tanpa token, 403 bukan admin, 400 array kosong/terlalu besar."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var j={}; try{ j=pm.response.json(); }catch(e){}",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.environment.set('refresh_token', j.data.refresh_token);",
                  "  pm.test('tokens captured', function () { pm.expect(j.data.access_token).to.be.a('string').and.not.empty; });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Login. 200 + {access_token, refresh_token}. Token disimpan otomatis ke environment."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var j={}; try{ j=pm.response.json(); }catch(e){}",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.environment.set('refresh_token', j.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "description": "Tukar refresh token → token pair baru. 401 jika token invalid / bukan tipe refresh / token_version mismatch (revoked)."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"{{password}}\",\n  \"new_password\": \"newSecret456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth", "change-password"] },
            "description": "Ubah password sendiri (Bearer). 200 → refresh token lama tercabut (token_version bump), login ulang. 400 INVALID_OLD_PASSWORD bila old_password salah."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] },
            "description": "Revoke refresh token milik sendiri (token_version bump). 200. Access token tetap sah sampai TTL habis."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] },
            "description": "Minta link reset. SELALU 200 (anti user-enumeration). Tanpa SMTP → token muncul di log server (WARN 'email (MOCK, not sent)'). Salin token ke {{reset_token}} untuk Reset Password."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"resetPass789\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] },
            "description": "Set password baru pakai token dari email (sekali pakai). 200 → login ulang. 400 INVALID_RESET_TOKEN bila token invalid/kedaluwarsa/sudah dipakai."
          }
        }
      ]
    },
    {
      "name": "user",
      "description": "Semua endpoint butuh Bearer {{access_token}} (jalankan Login dulu).",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] },
            "description": "Profil user dari token. 401 tanpa token."
          }
        },
        {
          "name": "Get by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] },
            "description": "Ambil user by id (tenant-scoped). 403 jika beda organization, 404 jika tak ada."
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] },
            "description": "Update name/password (tenant-scoped). Email & organizationCode immutable."
          }
        },
        {
          "name": "Change Role (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/users/{{user_id}}/role", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}", "role"] },
            "description": "ADMIN ONLY. Ubah role user jadi 'admin' atau 'user'. 400 kalau role invalid / ubah role sendiri; 403 kalau bukan admin."
          }
        },
        {
          "name": "Delete (soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] },
            "description": "ADMIN ONLY. Soft delete (set deleted_at). 403 kalau bukan admin. User tak bisa login lagi; email bebas dipakai ulang."
          }
        }
      ]
    },
    {
      "name": "upload",
      "description": "Chunked large-file upload (PDF). Chunking dilakukan client-side; tiap chunk (non-terakhir) WAJIB >= 5 MiB. Jalankan Login dulu untuk mengisi {{access_token}}.",
      "item": [
        {
          "name": "Chunk (single)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "Pilih file chunk (>=5 MiB kecuali chunk terakhir)" },
                { "key": "sessionId", "value": "{{upload_session_id}}", "type": "text", "description": "UUID sesi, stabil antar chunk" },
                { "key": "fileName", "value": "document.pdf", "type": "text" },
                { "key": "chunkIndex", "value": "0", "type": "text", "description": "0-based" },
                { "key": "totalChunks", "value": "1", "type": "text" },
                { "key": "fileSize", "value": "6000000", "type": "text", "description": "ukuran total file (bytes)" },
                { "key": "chunkSize", "value": "6000000", "type": "text" },
                { "key": "sha256", "value": "", "type": "text", "description": "SHA-256 seluruh file (dedup)" },
                { "key": "forceUpload", "value": "false", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/uploads/chunk", "host": ["{{base_url}}"], "path": ["uploads", "chunk"] },
            "description": "Upload 1 chunk. Ulang dengan chunkIndex 0..totalChunks-1 & sessionId sama. Chunk terakhir memicu merge → response memuat upload_complete=true, object_path, preview_url. 400 (validasi/type/size) · 409 duplikat sha256 · 429 kuota habis."
          }
        }
      ]
    },
    {
      "name": "document",
      "description": "Dokumen hasil upload (dari upload_logs). User biasa hanya org-nya; admin lihat semua. Login dulu untuk {{access_token}}.",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/documents", "host": ["{{base_url}}"], "path": ["documents"] },
            "description": "List dokumen. Scope by org token (admin: semua). Tiap item punya preview_url."
          }
        },
        {
          "name": "Get by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var j={}; try{ j=pm.response.json(); }catch(e){}",
                  "if (j.data && j.data.preview_url) { pm.environment.set('document_preview_url', j.data.preview_url); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/documents/{{document_id}}", "host": ["{{base_url}}"], "path": ["documents", "{{document_id}}"] },
            "description": "Detail 1 dokumen + presigned preview_url (bisa dibuka untuk download). 403 kalau beda org, 404 kalau tak ada."
          }
        }
      ]
    },
    {
      "name": "chat",
      "description": "Conversation / RAG Q&A. session_id = UUID dari client (id sama = percakapan sama). AI masih mock. Login dulu untuk {{access_token}}.",
      "item": [
        {
          "name": "Ask",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{chat_session_id}}\",\n  \"question\": \"Ringkas dokumen laporan tahunan\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/chat/ask", "host": ["{{base_url}}"], "path": ["chat", "ask"] },
            "description": "Tanya RAG. Isi {{chat_session_id}} dgn UUID (buat sendiri; pakai id sama untuk lanjut percakapan). 400 kalau session_id invalid, 404 kalau session milik user lain."
          }
        },
        {
          "name": "List sessions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/chat/sessions", "host": ["{{base_url}}"], "path": ["chat", "sessions"] },
            "description": "Daftar percakapan milik user (urut terbaru)."
          }
        },
        {
          "name": "Get session",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/chat/sessions/{{chat_session_id}}", "host": ["{{base_url}}"], "path": ["chat", "sessions", "{{chat_session_id}}"] },
            "description": "Detail 1 percakapan + semua pesan. 404 kalau bukan milik user."
          }
        },
        {
          "name": "Delete session",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/chat/sessions/{{chat_session_id}}", "host": ["{{base_url}}"], "path": ["chat", "sessions", "{{chat_session_id}}"] },
            "description": "Hapus percakapan + pesannya. 404 kalau bukan milik user."
          }
        }
      ]
    },
    {
      "name": "organization",
      "description": "Registry tenant. organization_code di seluruh app harus merujuk org yang ada & aktif. Read = semua user; write = admin.",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/organizations", "host": ["{{base_url}}"], "path": ["organizations"] }
          }
        },
        {
          "name": "Get",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/organizations/{{organization_code}}", "host": ["{{base_url}}"], "path": ["organizations", "{{organization_code}}"] }
          }
        },
        {
          "name": "Create (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"newco\",\n  \"name\": \"New Company\",\n  \"description\": \"\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/organizations", "host": ["{{base_url}}"], "path": ["organizations"] },
            "description": "ADMIN ONLY. 400 code invalid, 409 sudah ada."
          }
        },
        {
          "name": "Update (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated\",\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/organizations/{{organization_code}}", "host": ["{{base_url}}"], "path": ["organizations", "{{organization_code}}"] },
            "description": "ADMIN ONLY. active:false memblokir registrasi baru (user existing tetap jalan)."
          }
        },
        {
          "name": "Delete (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/organizations/{{organization_code}}", "host": ["{{base_url}}"], "path": ["organizations", "{{organization_code}}"] },
            "description": "ADMIN ONLY. 409 ORG_HAS_USERS kalau masih ada user aktif."
          }
        }
      ]
    },
    {
      "name": "debug",
      "description": "Endpoint verifikasi Sentry — HANYA aktif saat APP_ENV != production (di prod → 404). Setelah hit, cek Sentry → Issues.",
      "item": [
        {
          "name": "Force Error (500 -> Sentry)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/debug/error", "host": ["{{base_url}}"], "path": ["debug", "error"] },
            "description": "Paksa 500 (DEBUG_FORCED_ERROR). Log ERROR → tercapture di Sentry sebagai exception."
          }
        },
        {
          "name": "Force Panic (500 -> Sentry)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/debug/panic", "host": ["{{base_url}}"], "path": ["debug", "panic"] },
            "description": "Paksa panic → middleware.Recovery → 500 INTERNAL_ERROR (stack tak bocor) → Sentry exception."
          }
        },
        {
          "name": "Force Warn Message (200)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/debug/message", "host": ["{{base_url}}"], "path": ["debug", "message"] },
            "description": "Emit log WARN + 200. Masuk Sentry HANYA bila SENTRY_LEVEL=warn (default error = tidak)."
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "upload_session_id", "value": "", "type": "string" },
    { "key": "document_id", "value": "", "type": "string" },
    { "key": "chat_session_id", "value": "3f2504e0-4f89-41d3-9a0c-0305e82c3301", "type": "string" },
    { "key": "organization_code", "value": "pln", "type": "string" },
    { "key": "base_url", "value": "http://localhost:8080/api/v1", "type": "string" }
  ]
}
