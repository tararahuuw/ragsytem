# Application
APP_NAME=ragsystem
APP_ENV=development

# HTTP server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ragsystem
DB_SSLMODE=disable

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# MinIO / object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ragsystem
MINIO_USE_SSL=false

# Upload
UPLOAD_MAX_FILE_SIZE=524288000
UPLOAD_PREVIEW_EXPIRY=3h

# AI / RAG service (kosong = mock sampai kontrak tim AI siap)
AI_BASE_URL=
AI_TOKEN=
AI_TIMEOUT=30s

# Rate limiting (req/menit per key; 0 = unlimited)
RATELIMIT_ENABLED=true
RATELIMIT_AUTH_PER_MIN=20
RATELIMIT_CHAT_PER_MIN=20
RATELIMIT_UPLOAD_PER_MIN=300

# Email / SMTP (kosong = mock: email di-log, tak dikirim)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@ragsystem.local

# App base URL (link reset password) + TTL token reset
APP_BASE_URL=http://localhost:8080
PASSWORD_RESET_TTL=30m

# Sentry error monitoring. Kosongkan SENTRY_DSN untuk mematikan (error hanya di-log lokal).
# SENTRY_ENVIRONMENT kosong = ikut APP_ENV. SENTRY_LEVEL: error (default) | warn (ikut 4xx).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_LEVEL=error
SENTRY_TRACES_SAMPLE_RATE=0.0

# Redis caching. Kosongkan REDIS_ADDR (atau CACHE_ENABLED=false) untuk mematikan (no-op → DB).
# Lokal: jalankan `brew install redis && brew services start redis`, set REDIS_ADDR=localhost:6379.
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
CACHE_ENABLED=true
CACHE_TTL=5m
